# Osabio Environment Configuration — OpenRouter (default)
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# For Ollama, see .env.ollama.example instead.

# ── LLM Provider ─────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key

# -- Sandbox Agent ----------------------------
SANDBOX_AGENT_ENABLED=true
SANDBOX_AGENT_TYPE=claude

# ── Model IDs ────────────────────────────────────────────────
# Use model IDs from https://openrouter.ai/models
CHAT_AGENT_MODEL=openai/gpt-4.1-mini
EXTRACTION_MODEL=openai/gpt-4.1-mini
ANALYTICS_MODEL=openai/gpt-4.1-mini
PM_AGENT_MODEL=openai/gpt-4.1-mini
# OBSERVER_MODEL=openai/gpt-4.1-mini    # defaults to EXTRACTION_MODEL
# SCORER_MODEL=openai/gpt-4.1-mini      # defaults to EXTRACTION_MODEL

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Extraction Thresholds ────────────────────────────────────
EXTRACTION_STORE_THRESHOLD=0.6
EXTRACTION_DISPLAY_THRESHOLD=0.85

# ── SurrealDB ────────────────────────────────────────────────
SURREAL_URL=ws://127.0.0.1:8000/rpc
SURREAL_USERNAME=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=brain
SURREAL_DATABASE=app

# ── LLM Proxy ──────────────────────────────────────────────
# Server-held Anthropic key for osabio-auth proxy mode (optional).
# When set, osabio-auth requests inject this as x-api-key to upstream Anthropic.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Server ───────────────────────────────────────────────────
PORT=3000
# Auth base URL — origin only, without /api/auth suffix.
# The OAuth provider derives valid token audiences from this value.
BETTER_AUTH_URL=http://localhost:3000
