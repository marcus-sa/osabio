# Brain Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ─────────────────────────────────────────────
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=your_openrouter_key

# Option B: Ollama (uncomment and set INFERENCE_PROVIDER)
# INFERENCE_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Model IDs ────────────────────────────────────────────────
# For OpenRouter, use model IDs from https://openrouter.ai/models
# For Ollama, use your local model names
CHAT_AGENT_MODEL=openai/gpt-4.1-mini
EXTRACTION_MODEL=openai/gpt-4.1-mini
ANALYTICS_MODEL=openai/gpt-4.1-mini
PM_AGENT_MODEL=openai/gpt-4.1-mini

# ── Embeddings ───────────────────────────────────────────────
# OpenRouter embedding model (or Ollama model name)
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Extraction Thresholds ────────────────────────────────────
EXTRACTION_STORE_THRESHOLD=0.6
EXTRACTION_DISPLAY_THRESHOLD=0.85

# ── SurrealDB ────────────────────────────────────────────────
SURREAL_URL=ws://127.0.0.1:8000/rpc
SURREAL_USERNAME=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=brain
SURREAL_DATABASE=app

# ── Server ───────────────────────────────────────────────────
PORT=3000
