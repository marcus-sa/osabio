# Osabio Environment Configuration — Ollama (local inference)
# Copy this file to .env and adjust model names:
#   cp .env.ollama.example .env
# Requires Ollama running locally: https://ollama.com

# ── LLM Provider ─────────────────────────────────────────────
INFERENCE_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Model IDs ────────────────────────────────────────────────
# Use your local Ollama model names (run `ollama list` to see available)
# Recommended for 64GB Mac: qwen3:32b (~20GB RAM)
CHAT_AGENT_MODEL=qwen3:32b
EXTRACTION_MODEL=qwen3:32b
ANALYTICS_MODEL=qwen3:32b
PM_AGENT_MODEL=qwen3:32b
# OBSERVER_MODEL=qwen3:32b              # defaults to EXTRACTION_MODEL
# SCORER_MODEL=qwen3:32b                # defaults to EXTRACTION_MODEL

# ── Embeddings ───────────────────────────────────────────────
# Recommended: nomic-embed-text (~300MB RAM, 768 dimensions)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# ── Extraction Thresholds ────────────────────────────────────
EXTRACTION_STORE_THRESHOLD=0.6
EXTRACTION_DISPLAY_THRESHOLD=0.85

# ── SurrealDB ────────────────────────────────────────────────
SURREAL_URL=ws://127.0.0.1:8000/rpc
SURREAL_USERNAME=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=brain
SURREAL_DATABASE=app

# ── Auth ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ── Server ───────────────────────────────────────────────────
PORT=3000
