{
  "name": "brain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=.env app/server.ts",
    "start": "bun run app/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/unit/",
    "test:smoke": "bun test --env-file=.env tests/smoke/",
    "eval": "evalite run evals/",
    "eval:watch": "evalite watch evals/",
    "smoke:phase1": "bun run app/scripts/smoke-phase1.ts",
    "smoke:logging": "bun run app/scripts/smoke-logging.ts",
    "smoke:onboarding": "bun run app/scripts/smoke-onboarding.ts",
    "smoke:readme-import": "bun run app/scripts/smoke-readme-import.ts",
    "smoke:extraction-quality": "bun run app/scripts/smoke-extraction-quality.ts"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@tanstack/react-router": "^1.131.24",
    "ai": "^6.0.101",
    "pino": "^10.3.1",
    "reachat": "^3.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "reaviz": "^16.1.2",
    "surrealdb": "2.0.0-alpha.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "autoevals": "^0.0.132",
    "bun-types": "^1.3.5",
    "dotenv": "^17.3.1",
    "evalite": "^0.19.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
