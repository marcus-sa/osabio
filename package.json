{
  "name": "brain",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "bin": {
    "brain": "cli/brain.ts"
  },
  "scripts": {
    "dev": "bun --watch --env-file=.env app/server.ts",
    "start": "bun run app/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/unit/",
    "test:acceptance": "bun --env-file=.env scripts/test-acceptance.ts",
    "eval": "evalite run evals/",
    "eval:analytics": "evalite run evals/analytics.eval.ts",
    "eval:chat": "evalite run evals/chat-agent.eval.ts",
    "eval:watch": "evalite watch evals/",
    "acceptance:auth": "bun test --concurrent --timeout=180000 --env-file=.env tests/acceptance/auth/",
    "acceptance:chat": "bun test --concurrent --timeout=180000 --env-file=.env tests/acceptance/chat/",
    "acceptance:extraction": "bun test --concurrent --timeout=180000 --env-file=.env tests/acceptance/extraction/",
    "acceptance:graph": "bun test --concurrent --timeout=180000 --env-file=.env tests/acceptance/graph/",
    "acceptance:workspace": "bun test --concurrent --timeout=180000 --env-file=.env tests/acceptance/workspace/",
    "migrate": "bun run --env-file=.env schema/migrate.ts",
    "build:cli": "bun build cli/brain.ts --compile --bytecode --minify --outfile brain"
  },
  "dependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@ai-sdk/react": "^3.0.113",
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@better-auth/oauth-provider": "^1.5.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@tanstack/react-router": "^1.131.24",
    "ai": "^6.0.101",
    "better-auth": "^1.5.3",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-string": "^4.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "pino": "^10.3.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "reagraph": "^4.30.8",
    "reaviz": "^16.1.2",
    "surrealdb": "2.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "autoevals": "^0.0.132",
    "bun-types": "^1.3.5",
    "dotenv": "^17.3.1",
    "evalite": "^0.19.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
